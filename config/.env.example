# WordPress Configuration (stufenspezifisch)
# Die Skripte akzeptieren: -Environment dev|test|prod (Default: prod)
# WICHTIG: Es werden nur noch die jeweiligen Environment-Werte genutzt.
WP_URL_DEV=https://lawv8.scriptbb.de
WP_USER_DEV=lawadmin
WP_APP_PASSWORD_DEV=your-dev-app-password-here
WP_DEFAULT_CATEGORY_DEV=14

WP_URL_TEST=https://lawv8.scriptbb.de
WP_USER_TEST=lawadmin
WP_APP_PASSWORD_TEST=your-test-app-password-here
WP_DEFAULT_CATEGORY_TEST=14

WP_URL_PROD=https://law.scriptbb.de
WP_USER_PROD=lawadmin
WP_APP_PASSWORD_PROD=your-prod-app-password-here
WP_DEFAULT_CATEGORY_PROD=14

# AI Configuration (wähle einen Provider)
# Option 1: Claude/Anthropic (EMPFOHLEN für Rechtstexte!)
AI_PROVIDER=claude
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Option 2: Google Gemini (kostenlos)
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=models/gemini-2.0-flash

# Option 3: OpenAI (kostenpflichtig)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-your-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Gemeinsame AI Settings
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2500

# Content Settings
CONTENT_WORD_COUNT=1000
CONTENT_LANGUAGE=Deutsch
CONTENT_TAG_COUNT=5
